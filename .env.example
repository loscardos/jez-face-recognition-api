# Face Recognition API Configuration - DeepFace

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Laravel Backend
LARAVEL_API_URL=http://localhost:8000/api
LARAVEL_API_TOKEN=your_token_here

# DeepFace Model Configuration
# Model options: Facenet, Facenet512, ArcFace, VGG-Face, OpenFace
# Facenet: Ringan, cepat, akurasi baik (RECOMMENDED untuk 200 users)
# ArcFace: Akurasi tinggi, sedikit lebih berat
# VGG-Face: Akurasi tinggi tapi berat
DEEPFACE_MODEL=Facenet

# Face Detector Backend
# Options: opencv (cepat), retinaface (akurat), mtcnn, ssd, dlib
# opencv: Cepat, cocok untuk server tanpa GPU
# retinaface: Akurat untuk wajah dengan variasi angle
DEEPFACE_DETECTOR=opencv

# Model cache directory
DEEPFACE_HOME=/home/royyan/projects/face-attendance-ai/.deepface

# Face Matching Threshold (cosine similarity)
# Facenet: 0.6-0.7 (default 0.65)
# ArcFace: 0.5-0.6
# Semakin tinggi = semakin ketat
FACE_MATCH_THRESHOLD=0.65

# Minimum detection confidence
MIN_DETECTION_CONFIDENCE=0.8
